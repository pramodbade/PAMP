# ============================================================
# PAMP Backend — Environment Reference
# ============================================================
#
# When running via Docker Compose (recommended):
#   These values are injected automatically from the ROOT .env file.
#   You do NOT need to create a separate backend/.env file.
#
# When running the backend directly (outside Docker) for local dev:
#   Copy this file to backend/.env and fill in your values.
# ============================================================

DATABASE_URL=postgresql://pamp_user:CHANGE_THIS_STRONG_PASSWORD@localhost:5432/pamp_db

# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
