# ============================================================
# PAMP — Environment Template
# Copy to .env and fill in real values before deploying.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=pamp_db
POSTGRES_USER=pamp_user
# WARNING: Do NOT use @ in the password — it breaks the PostgreSQL connection URL.
# Use only alphanumeric characters and: ! # $ % ^ & * ( ) _ + - =
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Backend JWT ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Frontend ──────────────────────────────────────────────────
# The URL the browser uses to reach the API (via nginx).
# Format: http://<VM_IP>/api
NEXT_PUBLIC_API_URL=http://YOUR_VM_IP/api
